{
  "project": {
    "id": "mirror-crates-io",
    "title": "Mirror-Crates.io",
    "description": "A high-speed crates.io mirror and metadata indexer written in Go and Rust, designed for APTlantis’ distributed package-mirror ecosystem. Handles delta synchronization, metadata compression, and traffic analytics.",
    "version": "1.4.2",
    "stage": "completed",
    "tags": ["rust", "go", "crates", "mirror", "aptlantis", "datasets", "backend"]
  },
  "metadata": {
    "created": "2024-06-14",
    "completed": "2025-03-02",
    "last_verified": "2025-10-08",
    "maintainer": "Herb",
    "license": "MIT",
    "languages_used": ["go", "rust", "python"],
    "language_primary": "go",
    "dependencies": {
      "go": ["colly", "fastjson", "termui", "sqlite"],
      "rust": ["serde", "reqwest", "rayon", "tokio"],
      "python": ["pandas", "pyyaml"]
    },
    "containerization": {
      "docker_compose": true,
      "orchestration": "aptlantis-dispatcher",
      "services": ["mirror-worker", "pulse-dashboard", "json-sink", "rsync-proxy"]
    }
  },
  "links": {
    "drive": "https://drive.google.com/drive/folders/<mirror-crates-drive-id>",
