    "src_rust": "/src/rust/",
    "datasets": "/datasets/",
    "configs": "/configs/",
    "logs": "/logs/",
    "containers": "/compose/",
    "archive": "/archive/"
  },
  "scripts": [
    {
      "name": "mirror_sync.go",
      "language": "go",
      "role": "core sync engine",
      "status": "stable",
      "version": 3
    },
    {
      "name": "repo_pulse.rs",
      "language": "rust",
      "role": "analytics dashboard worker",
      "status": "stable",
      "version": 2
    },
    {
      "name": "dispatcher_wrapper.py",
      "language": "python",
      "role": "cron-dispatched mirror job handler",
      "status": "stable",
      "version": 1
    },
